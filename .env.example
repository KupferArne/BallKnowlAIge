# Public client config only — safe for the GitHub Pages bundle.
# NEVER put service_role, OpenRouter, or other privileged keys here.
#
# Vite requires the VITE_ prefix (not NEXT_PUBLIC_).
# Use the Supabase "anon" or "publishable" key — never the secret/service_role key.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Optional: override Pages base path for local preview of production build
# VITE_BASE=/BallKnowlAIge/
